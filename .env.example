# ─── CONFIGURACIÓN DE GMAIL ───
EMAIL_USER=tu-email@gmail.com
# Creá una "Contraseña de aplicación" en: https://myaccount.google.com/apppasswords
EMAIL_PASS=tu-contraseña-de-aplicacion

# ─── PUERTO DEL SERVIDOR ───
PORT=3000

# ─── URL BASE (para links en emails y webhooks) ───
# En local: http://localhost:3000
# En Render: https://tu-app.onrender.com
BASE_URL=http://localhost:3000

# ─── SECRETO PARA JWT (cambiá esto por algo seguro) ───
JWT_SECRET=cambiá-esto-por-un-seguro-secreto

# ─── MERCADO PAGO ───
MP_ACCESS_TOKEN=APP_USR-tu-access-token
MP_PUBLIC_KEY=APP_USR-tu-public-key

# ─── ADMIN PANEL ───
ADMIN_USER=admin
ADMIN_PASS=cambiá-esto-por-una-contraseña-segura
ADMIN_EMAIL=tu-email@gmail.com
